{% extends 'admin/base.html.twig' %}

{% block title %}Ajouter un événement - MediLink{% endblock %}
{% block page_title %}Gestion des événements{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <p class="mb-0 text-secondary">Créer un nouvel événement.</p>
  </div>

  <div class="table-container" style="max-width: 700px;">
    {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
    <div style="padding: 20px;">
      <div class="form-group">
        <label for="{{ form.titre.vars.id }}">Titre</label>
        {{ form_widget(form.titre, { attr: { class: 'input', id: form.titre.vars.id } }) }}
        {{ form_errors(form.titre) }}
      </div>
      <div class="form-group">
        <label for="{{ form.description.vars.id }}">Description</label>
        <div style="display:flex; gap:8px; align-items:flex-start;">
          <div style="flex:1;">
            {{ form_widget(form.description, { attr: { class: 'input', rows: 3, id: form.description.vars.id } }) }}
          </div>
          <button
            type="button"
            class="btn-primary"
            id="btn-generate-event-description"
            style="white-space:nowrap; flex-shrink:0;"
          >
            <i class="fa-solid fa-wand-magic-sparkles"></i> Générer avec IA
          </button>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="{{ form.dateEvenement.vars.id }}">Date</label>
          {{ form_widget(form.dateEvenement, { attr: { class: 'input' } }) }}
          {{ form_errors(form.dateEvenement) }}
        </div>
        <div class="form-group">
          <label for="{{ form.type.vars.id }}">Type</label>
          {{ form_widget(form.type, { attr: { class: 'input' } }) }}
          {{ form_errors(form.type) }}
        </div>
      </div>
      <div class="form-group">
        <label for="{{ form.lieu.vars.id }}">Lieu</label>
        {{ form_widget(form.lieu, { attr: { class: 'input', placeholder: 'Ex: Salle A, ou une adresse pour la localiser sur la carte' } }) }}
        {{ form_errors(form.lieu) }}
      </div>
      {{ include('admin/event/_map_lieu.html.twig', { lieu_input_id: form.lieu.vars.id }) }}
      <div class="form-group">
        <label for="{{ form.photoFile.vars.id }}">Photo de l'événement</label>
        {{ form_widget(form.photoFile, { attr: { class: 'input' } }) }}
        {{ form_errors(form.photoFile) }}
        <p class="hint">JPEG, PNG, GIF ou WebP. Max 5 Mo. Optionnel.</p>
      </div>
      <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 12px; margin-top: 20px;">
        <div style="display: flex; gap: 12px;">
          <a href="{{ path('admin_events_index') }}" class="btn-secondary">Annuler</a>
          <button type="submit" class="btn-primary">Enregistrer</button>
        </div>
      </div>
    </div>
    {{ form_end(form) }}
  </div>
</section>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      const btn = document.getElementById('btn-generate-event-description');
      if (!btn) return;
      const titleInput = document.getElementById('{{ form.titre.vars.id }}');
      const descInput = document.getElementById('{{ form.description.vars.id }}');
      const url = '{{ path('admin_events_api_generate_description') }}';

      btn.addEventListener('click', function () {
        const title = (titleInput?.value || '').trim();
        if (!title) {
          alert('Veuillez saisir un titre avant de générer la description.');
          return;
        }
        btn.disabled = true;
        btn.textContent = 'Génération…';
        fetch(url, {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: 'title=' + encodeURIComponent(title)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.description) {
              if (descInput) descInput.value = data.description;
            } else {
              alert(data.error || 'Impossible de générer une description pour le moment.');
            }
          })
          .catch(function () {
            alert('Erreur lors de l\'appel au service IA.');
          })
          .finally(function () {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Générer avec IA';
          });
      });
    })();
  </script>
{% endblock %}
