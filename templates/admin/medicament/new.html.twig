{% extends 'admin/base.html.twig' %}

{% block title %}Ajouter un médicament - MediLink{% endblock %}
{% block page_title %}Médicaments{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <p class="mb-0 text-secondary">Nouveau médicament. <a href="{{ path('admin_medicaments_index') }}"><i class="fa-solid fa-arrow-left"></i> Retour à la liste</a></p>
  </div>

  {{ form_start(form) }}
  {{ form_errors(form) }}
  <div class="form-row">
    <div class="form-group">
      <label for="{{ form.nom.vars.id }}">Nom</label>
      {{ form_widget(form.nom, { attr: { class: 'input', placeholder: 'Nom du médicament' } }) }}
      {{ form_errors(form.nom) }}
    </div>
    <div class="form-group">
      <label for="{{ form.quantiteStock.vars.id }}">Quantité en stock</label>
      {{ form_widget(form.quantiteStock, { attr: { class: 'input', min: 0 } }) }}
      {{ form_errors(form.quantiteStock) }}
    </div>
  </div>
  <div class="form-group">
    <label for="{{ form.description.vars.id }}">Description</label>
    <div style="display:flex; gap:8px; align-items:flex-start;">
      <div style="flex:1;">
        {{ form_widget(form.description, { attr: { class: 'input', rows: 3, id: form.description.vars.id } }) }}
      </div>
      <button
        type="button"
        class="btn-primary"
        id="btn-generate-medicament-description"
        style="white-space:nowrap; flex-shrink:0;"
      >
        <i class="fa-solid fa-wand-magic-sparkles"></i> Générer avec IA
      </button>
    </div>
    {{ form_errors(form.description) }}
  </div>
  <div class="form-actions">
    <a href="{{ path('admin_medicaments_index') }}" class="btn-secondary">Annuler</a>
    <button type="submit" class="btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
  </div>
  {{ form_end(form) }}
</section>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      const btn = document.getElementById('btn-generate-medicament-description');
      if (!btn) return;
      const nomInput = document.getElementById('{{ form.nom.vars.id }}');
      const descInput = document.getElementById('{{ form.description.vars.id }}');
      const url = '{{ path('admin_medicaments_generate_description') }}';

      btn.addEventListener('click', function () {
        const nom = (nomInput?.value || '').trim();
        if (!nom) {
          alert('Veuillez saisir le nom du médicament avant de générer la description.');
          return;
        }
        btn.disabled = true;
        btn.textContent = 'Génération…';
        fetch(url, {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: 'nom=' + encodeURIComponent(nom)
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.description) {
              if (descInput) descInput.value = data.description;
            } else {
              alert(data.error || 'Impossible de générer une description pour le moment.');
            }
          })
          .catch(function () {
            alert('Erreur lors de l\'appel au service IA.');
          })
          .finally(function () {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Générer avec IA';
          });
      });
    })();
  </script>
{% endblock %}
