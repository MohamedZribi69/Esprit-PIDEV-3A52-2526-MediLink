{% extends 'security/auth_base.html.twig' %}

{% block title %}Mot de passe oublié | MediLink{% endblock %}

{% block content %}
  <div class="auth-head">
    <h1><i class="fa-solid fa-key"></i> Mot de passe oublié</h1>
  </div>

  <div class="auth-body">
    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : 'error' }}">
          {{ message }}
        </div>
      {% endfor %}
    {% endfor %}

    <form method="post" action="{{ path('app_forgot_password') }}">
      <div class="form-group">
        <label for="email"><i class="fa-solid fa-envelope"></i> Adresse e-mail</label>
        <input
          class="input"
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="ex: user@medilink.tn"
          value="{{ last_email|default('') }}"
        >
      </div>

      <button class="btn-primary" type="submit">
        <i class="fa-solid fa-paper-plane"></i> Envoyer un nouveau mot de passe
      </button>

      <p class="hint">
        Un nouveau mot de passe temporaire vous sera envoyé par e-mail. Pensez à le modifier après connexion.
      </p>

      <p class="hint" style="margin-top: 18px;">
        <a class="link" href="{{ path('app_login') }}">
          <i class="fa-solid fa-arrow-left"></i> Retour à la connexion
        </a>
      </p>
    </form>
  </div>
{% endblock %}

